<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_history"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentTop="true">

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminate="true" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Riwayat Ujian"
                android:textColor="#000000"
                android:textSize="24sp"
                android:textStyle="bold" />
            <ImageView
                android:id="@+id/btnFilter"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_tune"
                app:tint="#000000" />
        </RelativeLayout>

        <!-- Statistik Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:weightSum="2">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="115dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardBackgroundColor="@color/blue"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_poll"
                            app:tint="#FFFFFF"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RATA-RATA NILAI"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginStart="6dp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvRataNilai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="85%"
                        android:textColor="#FFFFFF"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="115dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="#0097B2"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SELESAI"
                            android:textColor="#0097B2"
                            android:textSize="10sp"
                            android:layout_marginStart="6dp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvJumlahSelesai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textColor="#000000"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7 hari terakhir"
                        android:textColor="#9E9E9E"
                        android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Chip Filter (Horizontal Scroll) -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="4dp"
            android:layout_marginHorizontal="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <!-- Semua chip dari layout asli, silakan salin lengkap -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipSemua"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:checkable="true"
                android:checked="true"
                android:text="Semua"
                android:textColor="@color/chip_text_color"
                android:textSize="13sp"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_color_selector"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="#14000000"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMatematika"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:checkable="true"
                android:text="Matematika"
                android:textColor="@color/chip_text_color"
                android:textSize="13sp"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_color_selector"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="#40000000"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSejarah"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:checkable="true"
                android:text="Sejarah"
                android:textColor="@color/chip_text_color"
                android:textSize="13sp"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_color_selector"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="#40000000"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipBahasaInggris"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:checkable="true"
                android:text="Bahasa Inggris"
                android:textColor="@color/chip_text_color"
                android:textSize="13sp"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_color_selector"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="#40000000"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipBahasaIndonesia"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:checkable="true"
                android:text="Bahasa Indonesia"
                android:textColor="@color/chip_text_color"
                android:textSize="13sp"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_color_selector"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="#40000000"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAgama"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:checkable="true"
                android:text="Agama"
                android:textColor="@color/chip_text_color"
                android:textSize="13sp"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_color_selector"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="#40000000"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMPP"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:checkable="true"
                android:text="MPP"
                android:textColor="@color/chip_text_color"
                android:textSize="13sp"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_color_selector"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="#40000000"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipKK"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:checkable="true"
                android:text="KK"
                android:textColor="@color/chip_text_color"
                android:textSize="13sp"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_color_selector"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="#40000000"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipOlahRaga"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:checkable="true"
                android:text="Olah Raga"
                android:textColor="@color/chip_text_color"
                android:textSize="13sp"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_color_selector"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="#40000000"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPKK"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:checkable="true"
                android:text="PKK"
                android:textColor="@color/chip_text_color"
                android:textSize="13sp"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_color_selector"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="#40000000"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPKN"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:checkable="true"
                android:text="PKN"
                android:textColor="@color/chip_text_color"
                android:textSize="13sp"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_color_selector"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="#40000000"
                app:chipStrokeWidth="1dp" />

        </LinearLayout>
        </HorizontalScrollView>

        <!-- Label "HASIL TERBARU" -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HASIL TERBARU"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#757575"
            android:layout_margin="16dp" />
    </LinearLayout>

    <!-- RECYCLERVIEW UNTUK DAFTAR RIWAYAT (SCROLLABLE) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHistory"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerContainer"
        android:layout_above="@id/bottomNavigation"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        android:scrollbars="vertical" />

    <!-- BOTTOM NAVIGATION -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/btn_blue"
        android:elevation="10dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="10dp"
            android:src="@drawable/ic_home"
            app:tint="#FFFFFF" />

        <ImageView
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="9dp"
            android:src="@drawable/ic_history"
            app:tint="#FFFFFF" />

        <ImageView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="10dp"
            android:src="@drawable/ic_person"
            app:tint="#FFFFFF" />
    </LinearLayout>

</RelativeLayout>