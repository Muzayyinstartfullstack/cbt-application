<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="20dp">

    <!-- Header dengan close button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="15dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Navigasi Soal"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_close_nav"
            android:layout_width="90dp"
            android:layout_height="35dp"
            android:text="45 Soal"
            android:background="@drawable/bg_grey"
            android:textColor="#666666"
            android:paddingVertical="5dp"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#e0e0e0"
        android:layout_marginBottom="15dp" />

    <!-- Filter Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:id="@+id/filter_dijawab"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="10dp"
            android:background="@drawable/bg_grey"
            android:layout_marginEnd="8dp">

            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@drawable/ic_selesai"
                android:layout_marginBottom="5dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DIJAWAB"
                android:textSize="10sp"
                android:textColor="#666666"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/filter_ragu"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="10dp"
            android:background="@drawable/bg_grey"
            android:layout_marginEnd="8dp">

            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@drawable/ic_raguragu"
                android:layout_marginBottom="5dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RAGU-RAGU"
                android:textSize="10sp"
                android:textColor="#666666"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/filter_belum"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="10dp"
            android:background="@drawable/bg_grey">

            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@drawable/ic_belum"
                android:layout_marginBottom="5dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BELUM"
                android:textSize="10sp"
                android:textColor="#666666"
                android:gravity="center" />
        </LinearLayout>
    </LinearLayout>

    <!-- Grid Soal dengan RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/question_grid_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:nestedScrollingEnabled="false" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#e0e0e0"
        android:layout_marginBottom="15dp" />

    <!-- Tombol Selesaikan Exam -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_selesai"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Selesaikan Ujian"
        android:background="@drawable/bg_btn_solid"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Warning text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PASTIKAN SEMUA SOAL TELAH TERJAWAB"
        android:textSize="11sp"
        android:textColor="#999999"
        android:gravity="center"
        android:layout_marginTop="10dp" />
</LinearLayout>