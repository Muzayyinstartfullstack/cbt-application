<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:background="@drawable/bg_detail_header"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_chevron_left"
                    app:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:text="Detail Hasil Ujian"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MATA PELAJARAN"
                        android:textColor="#CCFFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/tvDetailMapel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Matematika"
                        android:textColor="#FFFFFF"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:layout_marginTop="16dp">

                        <ProgressBar
                            android:id="@+id/progressCircle"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:max="100"
                            android:progress="86"
                            android:progressDrawable="@drawable/circular_progress_bar" />

                        <TextView
                            android:id="@+id/tvSkorBesar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="86%"
                            android:textColor="#FFFFFF"
                            android:textSize="36sp"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </LinearLayout>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-50dp"
                android:paddingHorizontal="16dp"
                android:orientation="vertical">

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins">

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="4dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:gravity="center_vertical">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_time" app:tint="#0097B2"/>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WAKTU" android:textSize="10sp" android:textColor="#9E9E9E" android:textStyle="bold"/>
                                <TextView android:id="@+id/tvWaktu" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="90m" android:textSize="16sp" android:textStyle="bold" android:textColor="#212121"/>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="4dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:gravity="center_vertical">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_check_circle" app:tint="#4CAF50"/>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BENAR" android:textSize="10sp" android:textColor="#9E9E9E" android:textStyle="bold"/>
                                <TextView android:id="@+id/tvBenar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="39/45" android:textSize="16sp" android:textStyle="bold" android:textColor="#212121"/>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="4dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:gravity="center_vertical">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_close" app:tint="#F44336"/>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SALAH" android:textSize="10sp" android:textColor="#9E9E9E" android:textStyle="bold"/>
                                <TextView android:id="@+id/tvSalah" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="6" android:textSize="16sp" android:textStyle="bold" android:textColor="#212121"/>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="4dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:gravity="center_vertical">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_leaderboard" app:tint="#FFB74D"/>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PERINGKAT" android:textSize="10sp" android:textColor="#9E9E9E" android:textStyle="bold"/>
                                <TextView android:id="@+id/tvPeringkat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#13 / 36" android:textSize="16sp" android:textStyle="bold" android:textColor="#212121"/>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </GridLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginHorizontal="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Analisis Topik"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#212121"/>

                    <TextView
                        android:id="@+id/tvDetailLengkap"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Detail Lengkap"
                        android:textColor="#0097B2"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp">

                    <include
                        android:id="@+id/item1"
                        layout="@layout/item_topic_analysis" />

                    <include
                        android:id="@+id/item2"
                        layout="@layout/item_topic_analysis" />

                    <include
                        android:id="@+id/item3"
                        layout="@layout/item_topic_analysis" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPembahasan"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginVertical="32dp"
                    android:text="Lihat Pembahasan Soal"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#0097B2"
                    android:textColor="#FFFFFF"
                    app:icon="@drawable/ic_book"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>