<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/bg_code_input.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item
        android:left="0dp"
        android:right="0dp"
        android:top="0dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#0000000f" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- Border & Background -->
    <item
        android:left="0dp"
        android:right="0dp"
        android:top="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/white" />
            <stroke
                android:width="1dp"
                android:color="#26000000" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>