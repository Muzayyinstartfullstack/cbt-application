package com.example.cbt.data.model

import kotlinx.serialization.Serializable
import kotlinx.serialization.SerialName

@Serializable
data class Subject(
    val id: Int,
    val name: String,
    val description: String?,
    @SerialName("image_url") val imageUrl: String?,
    @SerialName("created_at") val createdAt: String
)

@Serializable
data class Topic(
    val id: Int,
    @SerialName("subject_id") val subjectId: Int,
    val name: String,
    @SerialName("created_at") val createdAt: String
)

@Serializable
data class AnswerOption(
    val id: Int,
    @SerialName("question_id") val questionId: Int,
    @SerialName("option_text") val optionText: String,
    @SerialName("is_correct") val isCorrect: Boolean,
    @SerialName("created_at") val createdAt: String
)

@Serializable
data class Question(
    val id: Int,
    @SerialName("exam_id") val examId: Int,
    @SerialName("topic_id") val topicId: Int?,
    @SerialName("question_text") val questionText: String,
    @SerialName("image_url") val imageUrl: String?,
    val poin: Int,
    @SerialName("created_at") val createdAt: String,
    @SerialName("answer_options") val answerOptions: List<AnswerOption> = emptyList()
)

@Serializable
data class Exam(
    val id: Int,
    val title: String,
    val description: String?,
    @SerialName("subject_id") val subjectId: Int,
    @SerialName("start_time") val startTime: String,
    @SerialName("end_time") val endTime: String,
    @SerialName("duration_minutes") val durationMinutes: Int,
    @SerialName("shuffle_questions") val shuffleQuestions: Boolean,
    @SerialName("shuffle_options") val shuffleOptions: Boolean,
    @SerialName("image_url") val imageUrl: String?,
    @SerialName("access_token") val accessToken: String,
    @SerialName("created_at") val createdAt: String
)

@Serializable
data class ExamWithDetails(
    val id: Int,
    val title: String,
    val description: String?,
    @SerialName("subject_id") val subjectId: Int,
    @SerialName("start_time") val startTime: String,
    @SerialName("end_time") val endTime: String,
    @SerialName("duration_minutes") val durationMinutes: Int,
    @SerialName("shuffle_questions") val shuffleQuestions: Boolean,
    @SerialName("shuffle_options") val shuffleOptions: Boolean,
    @SerialName("image_url") val imageUrl: String?,
    @SerialName("access_token") val accessToken: String,
    @SerialName("created_at") val createdAt: String,
    @SerialName("total_questions") val totalQuestions: Int,
    val status: String
)

@Serializable
data class ExamSession(
    val id: Int,
    @SerialName("exam_id") val examId: Int,
    @SerialName("user_id") val userId: String,
    @SerialName("started_at") val startedAt: String,
    @SerialName("completed_at") val completedAt: String?,
    val score: Int?,
    @SerialName("created_at") val createdAt: String,
    val exams: ExamWithDetails? = null,
    @SerialName("user_answers") val userAnswers: List<UserAnswerDetail>? = null
)

@Serializable
data class UserAnswerDetail(
    val id: Int,
    @SerialName("session_id") val sessionId: Int,
    @SerialName("question_id") val questionId: Int,
    @SerialName("answer_option_id") val answerOptionId: Int,
    @SerialName("is_correct") val isCorrect: Boolean?,
    @SerialName("created_at") val createdAt: String,
    val questions: Question? = null
)

@Serializable
data class ExamSessionWithStatus(
    val exam: Exam? = null,
    val id: Int,
    @SerialName("exam_id") val examId: Int,
    @SerialName("user_id") val userId: String,
    @SerialName("started_at") val startedAt: String,
    @SerialName("completed_at") val completedAt: String?,
    val score: Int?,
    @SerialName("created_at") val createdAt: String,
    val status: String
)

@Serializable
data class UserStatistics(
    val completedExams: Int,
    val averageScore: Double,
    val remedialCount: Int
)

@Serializable
data class Profile(
    val id: String,
    val email: String,
    val nis: String,
    @SerialName("full_name") val fullName: String?,
    @SerialName("tanggal_lahir") val tanggalLahir: String,
    val role: String
)

@Serializable
data class UserAnswer(
    val id: Int,
    @SerialName("session_id") val sessionId: Int,
    @SerialName("question_id") val questionId: Int,
    @SerialName("answer_option_id") val answerOptionId: Int,
    @SerialName("created_at") val createdAt: String
)

// Request/Response khusus
@Serializable
data class JoinExamRequest(
    @SerialName("access_token") val accessToken: String
)

@Serializable
@SerialName("SubmitAnswerRequest")
data class SubmitAnswerRequest(
    @SerialName("session_id") val sessionId: Int,
    @SerialName("question_id") val questionId: Int,
    @SerialName("answer_option_id") val answerOptionId: Int
)

@Serializable
data class CompleteExamRequest(
    @SerialName("session_id") val sessionId: Int,
    val score: Int
)